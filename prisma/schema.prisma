generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("USER")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile              Profile?
  moderatedGroups      Group[]       @relation("GroupModerator")
  applications         Application[]
  checkIns             CheckIn[]
  reports              Report[]
  feedback             Feedback[]
  analyticsEvents      AnalyticsEvent[]
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  displayName     String
  city            String   @default("Санкт-Петербург")
  interests       String   @default("[]")
  bio             String?
  trustedContact  String?
  telegramHandle  String?
  onboardingDone  Boolean  @default(false)
  consentAccepted Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Group {
  id            String   @id @default(cuid())
  kudagoEventId Int
  eventTitle    String
  eventDate     DateTime
  capacity      Int      @default(7)
  meetingPoint  String?
  telegramLink  String?
  status        String   @default("OPEN")
  moderatorId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  moderator    User          @relation("GroupModerator", fields: [moderatorId], references: [id])
  applications Application[]
  checkIns     CheckIn[]
  feedback     Feedback[]

  @@index([kudagoEventId])
}

model Application {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  status    String   @default("PENDING")
  message   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId, status])
}

model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  status    String   @default("checked_in")
  note      String?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Report {
  id        String   @id @default(cuid())
  userId    String
  groupId   String?
  type      String
  message   String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String?
  telegram  String?
  interests String?
  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  payload   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([name, createdAt])
}
